# ============================================================================
# Database Configuration
# ============================================================================
# MySQL/TiDB connection string
# Format: mysql://username:password@host:port/database
# Example: mysql://root:password@localhost:3306/dimas_portfolio
DATABASE_URL=mysql://user:password@localhost:3306/dimas_portfolio

# ============================================================================
# Authentication & Security
# ============================================================================
# JWT secret for session cookie signing (use a strong random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================================================
# OAuth Configuration (if using external OAuth)
# ============================================================================
# OAuth server URL (e.g., Manus OAuth or custom OAuth provider)
OAUTH_SERVER_URL=https://api.example.com/oauth

# OAuth application ID
VITE_APP_ID=your-oauth-app-id

# OAuth portal URL for login redirects
VITE_OAUTH_PORTAL_URL=https://auth.example.com/login

# ============================================================================
# Owner Information
# ============================================================================
# Owner's OpenID from OAuth provider
OWNER_OPEN_ID=owner-open-id-from-oauth

# Owner's name for notifications
OWNER_NAME=Dimas Stya Nugraha

# ============================================================================
# AWS S3 Configuration (for file storage)
# ============================================================================
# S3 bucket name
AWS_S3_BUCKET=your-bucket-name

# AWS region
AWS_REGION=us-east-1

# AWS access key ID
AWS_ACCESS_KEY_ID=your-access-key-id

# AWS secret access key
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 endpoint (optional, for custom S3-compatible services)
# AWS_S3_ENDPOINT=https://s3.amazonaws.com

# ============================================================================
# LLM/AI Services (if using Manus built-in APIs or external LLM)
# ============================================================================
# Built-in Forge API URL (Manus internal APIs for LLM, storage, etc.)
BUILT_IN_FORGE_API_URL=https://api.manus.im/forge

# Built-in Forge API key (server-side, for backend LLM calls)
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# Frontend Forge API URL (for client-side API calls)
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im/forge

# Frontend Forge API key (for client-side access)
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key

# ============================================================================
# Application Configuration
# ============================================================================
# Node environment
NODE_ENV=development

# Application title (displayed in browser tab and header)
VITE_APP_TITLE=Dimas Stya Nugraha — Digital Creative

# Application logo URL
VITE_APP_LOGO=https://your-cdn.com/logo.png

# ============================================================================
# Analytics (optional)
# ============================================================================
# Analytics endpoint URL
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com

# Analytics website ID
VITE_ANALYTICS_WEBSITE_ID=your-analytics-id

# ============================================================================
# Development/Debug (optional)
# ============================================================================
# Enable debug logging
DEBUG=false

# API base URL for development
VITE_API_BASE_URL=http://localhost:3000/api
